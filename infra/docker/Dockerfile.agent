FROM ubuntu:noble@sha256:84e77dee7d1bc93fb029a45e3c6cb9d8aa4831ccfcc7103d36e876938d28895b

LABEL org.opencontainers.image.source="https://github.com/ErichHubert/bugarena" \
      org.opencontainers.image.title="Bugarena Agent" \
      org.opencontainers.image.description="Codex-capable Bugarena workstation image with mise and baseline developer tooling." \
      org.opencontainers.image.licenses="MIT"

ARG DEBIAN_FRONTEND=noninteractive
ARG MISE_VERSION=v2025.11.11
ARG CODEX_VERSION=0.116.0

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates curl gpg xz-utils \
    && install -m 0755 -d /etc/apt/keyrings \
    && curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
        | gpg --dearmor -o /etc/apt/keyrings/githubcli-archive-keyring.gpg \
    && chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
        > /etc/apt/sources.list.d/github-cli.list \
    && curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key \
        | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg \
    && chmod go+r /etc/apt/keyrings/nodesource.gpg \
    && echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_22.x nodistro main" \
        > /etc/apt/sources.list.d/nodesource.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends \
        bash \
        build-essential \
        bubblewrap \
        cmake \
        fd-find \
        file \
        gh \
        git \
        jq \
        less \
        libbz2-dev \
        libffi-dev \
        liblzma-dev \
        libreadline-dev \
        libsqlite3-dev \
        libssl-dev \
        lsof \
        make \
        nano \
        nodejs \
        openssh-client \
        pipx \
        pkg-config \
        procps \
        python3 \
        python3-venv \
        ripgrep \
        sqlite3 \
        tree \
        unzip \
        wget \
        zip \
        zlib1g-dev \
    && curl -fsSL https://mise.run \
        | MISE_INSTALL_PATH=/usr/local/bin/mise MISE_VERSION=${MISE_VERSION} sh \
    && corepack enable \
    && npm install --global @openai/codex@${CODEX_VERSION} \
    && ln -sf /usr/bin/fdfind /usr/local/bin/fd \
    && useradd --create-home --shell /bin/bash agent \
    && install -m 0755 -d /opt/codex-agent \
    && install -m 0755 -d /etc/codex/skills \
    && install -m 0755 -d -o agent -g agent \
        /workspace \
        /home/agent/.cache \
        /home/agent/.codex \
        /home/agent/.config \
        /home/agent/.local \
        /home/agent/.local/bin \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

COPY --chmod=0755 infra/docker/docker-entrypoint.sh /usr/local/bin/docker-entrypoint.sh
COPY --chmod=0644 agent/bugarena-testinfra.sh /etc/profile.d/bugarena-testinfra.sh
COPY --chmod=0644 agent/bugarena-shell-env.sh /etc/profile.d/bugarena-shell-env.sh
COPY --chmod=0644 agent/codex-home-agents.md /opt/codex-agent/codex-home-agents.md
COPY --chmod=0644 agent/codex-home-config.toml /opt/codex-agent/codex-home-config.toml
COPY agent/skills/ /etc/codex/skills/

USER agent
ENV BASH_ENV=/etc/profile.d/bugarena-shell-env.sh
ENV HOME=/home/agent
ENV MISE_TRUSTED_CONFIG_PATHS=/workspace
WORKDIR /workspace

ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]
CMD ["bash"]
