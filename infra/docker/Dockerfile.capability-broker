FROM mcr.microsoft.com/dotnet/sdk:10.0-noble@sha256:8a90a473da5205a16979de99d2fc20975e922c68304f5c79d564e666dc3982fc AS build

WORKDIR /src

COPY Bugarena.sln ./
COPY src/CapabilityBroker/CapabilityBroker.csproj src/CapabilityBroker/
RUN dotnet restore src/CapabilityBroker/CapabilityBroker.csproj

COPY src/CapabilityBroker/ src/CapabilityBroker/
RUN dotnet publish src/CapabilityBroker/CapabilityBroker.csproj \
    -c Release \
    -o /app/publish \
    /p:UseAppHost=false

FROM mcr.microsoft.com/dotnet/aspnet:10.0-noble@sha256:55e37c7795bfaf6b9cc5d77c155811d9569f529d86e20647704bc1d7dd9741d4 AS final

LABEL org.opencontainers.image.source="https://github.com/ErichHubert/bugarena" \
      org.opencontainers.image.title="Bugarena Capability Broker" \
      org.opencontainers.image.description="Allowlist-based ASP.NET Core reverse proxy for secret-backed provider integrations." \
      org.opencontainers.image.licenses="MIT"

RUN apt-get update \
    && apt-get install -y --no-install-recommends curl \
    && useradd --system --create-home --home-dir /home/broker --shell /usr/sbin/nologin broker \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY --from=build --chown=broker:broker /app/publish/ ./

EXPOSE 8080

ENV ASPNETCORE_URLS=http://+:8080

USER broker

ENTRYPOINT ["dotnet", "CapabilityBroker.dll"]
