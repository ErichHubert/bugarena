FROM mcr.microsoft.com/dotnet/sdk:8.0-bookworm-slim

ARG DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates curl gnupg \
    && install -m 0755 -d /etc/apt/keyrings \
    && curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
        | dd of=/etc/apt/keyrings/githubcli-archive-keyring.gpg status=none \
    && chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
        > /etc/apt/sources.list.d/github-cli.list \
    && curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key \
        | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg \
    && chmod go+r /etc/apt/keyrings/nodesource.gpg \
    && echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_22.x nodistro main" \
        > /etc/apt/sources.list.d/nodesource.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends \
        bash \
        fd-find \
        gh \
        git \
        jq \
        less \
        lsof \
        nano \
        nodejs \
        procps \
        python3 \
        python3-pip \
        ripgrep \
        tree \
        unzip \
        wget \
        zip \
    && npm install --global @openai/codex \
    && ln -sf /usr/bin/fdfind /usr/local/bin/fd \
    && useradd --create-home --shell /bin/bash agent \
    && install -m 0755 -d /opt/codex-agent \
    && install -d -o agent -g agent /workspace \
    && install -d -o agent -g agent /home/agent/.codex /home/agent/.cache /home/agent/.config \
    && touch /workspace/.volume-root /home/agent/.codex/.keep /home/agent/.cache/.keep /home/agent/.config/.keep \
    && chown agent:agent /workspace/.volume-root /home/agent/.codex/.keep /home/agent/.cache/.keep /home/agent/.config/.keep \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

COPY --chmod=0755 docker-entrypoint.sh /usr/local/bin/docker-entrypoint.sh
COPY --chmod=0644 agent/container-AGENTS.md /opt/codex-agent/AGENTS.md
COPY --chown=agent:agent --chmod=0644 agent/container-AGENTS.md /workspace/AGENTS.md

USER agent
ENV HOME=/home/agent
WORKDIR /workspace

ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]
CMD ["bash"]
