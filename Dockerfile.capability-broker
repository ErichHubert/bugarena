FROM mcr.microsoft.com/dotnet/sdk:10.0-noble@sha256:478b9038d187e5b5c29bfa8173ded5d29e864b5ad06102a12106380ee01e2e49 AS build

WORKDIR /src

COPY Bugarena.sln ./
COPY src/CapabilityBroker/CapabilityBroker.csproj src/CapabilityBroker/
RUN dotnet restore src/CapabilityBroker/CapabilityBroker.csproj

COPY src/CapabilityBroker/ src/CapabilityBroker/
RUN dotnet publish src/CapabilityBroker/CapabilityBroker.csproj \
    -c Release \
    -o /app/publish \
    /p:UseAppHost=false

FROM mcr.microsoft.com/dotnet/aspnet:10.0-noble@sha256:a04d1c1d2d26119049494057d80ea6cda25bbd8aef7c444a1fc1ef874fd3955b AS final

RUN apt-get update \
    && apt-get install -y --no-install-recommends curl \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY --from=build /app/publish/ ./

EXPOSE 8080

ENV ASPNETCORE_URLS=http://+:8080

ENTRYPOINT ["dotnet", "CapabilityBroker.dll"]
